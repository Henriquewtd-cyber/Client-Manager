generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  email     String   @unique
  name      String
  password  String
  role      String
}

model Event {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  nomeCliente  String
  telefone     String   
  start        DateTime
  end          DateTime
  description  String?
  color        String
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Job {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  eventId      String   
  nome         String 
  telefone     String
  dataExec     DateTime
  tipo         String
  status       String
}


model Pagamentos {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  nomeCliente  String
  telefone     String
  estado       String   
  
  tipo         String
  url          String
  publicId    String
}
